# ── Email (IMAP/SMTP) ──────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=andereamru+walking-hounds@gmail.com
IMAP_PASSWORD=your-app-password-here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=andereamru+walking-hounds@gmail.com
SMTP_PASSWORD=your-app-password-here

# ── LLM (Ollama) ───────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Database ────────────────────────────────────────────────
DB_PATH=data/walking_hounds.db

# ── Business ───────────────────────────────────────────────
WALK_PRICE_EUR=20
LATE_CANCEL_HOURS=24
LATE_CANCEL_FEE_PERCENT=50
INVOICE_PAYMENT_ADDRESS=test-payment@walking-hounds.local

# ── Schedule ───────────────────────────────────────────────
WALK_SLOTS=11:30,12:00,12:30
MAX_DOGS_PER_GROUP=4
MAX_GROUPS_PER_DAY=3
MIN_GROUPS_PER_DAY=2
BUSINESS_DAYS=mon,tue,wed,thu,fri

# ── Intake ─────────────────────────────────────────────────
IMAP_POLL_INTERVAL_SEC=60
INTAKE_CONFIDENCE_THRESHOLD=0.75

# ── Reminders ──────────────────────────────────────────────
REMINDER_HOURS_BEFORE_WALK=2
REMINDER_POLL_INTERVAL_SEC=60

# ── Dashboard ──────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8010
