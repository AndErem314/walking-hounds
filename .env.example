# ── Email IMAP ──────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# ── Email SMTP ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── LLM ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Database ────────────────────────────────────────────
DB_PATH=data/walking_hounds.db

# ── Business ───────────────────────────────────────────
WALK_PRICE_EUR=20.0
LATE_CANCEL_HOURS=24
LATE_CANCEL_FEE_PERCENT=50
INVOICE_PAYMENT_ADDRESS=payments@walking-hounds.local

# ── Schedule ────────────────────────────────────────────
WALK_SLOTS=11:30,12:00,12:30
MAX_DOGS_PER_GROUP=4
MAX_GROUPS_PER_DAY=3
BUSINESS_DAYS=mon,tue,wed,thu,fri

# ── Dashboard ──────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8010

# ── Intake ─────────────────────────────────────────────
IMAP_POLL_INTERVAL_SEC=60
